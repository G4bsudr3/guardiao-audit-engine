# =============================================================================
# Guardiao Audit Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Service Auth ---
# Pre-shared API key for authenticating requests to this service.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_SERVICE_API_KEY=

# --- Claude ---
# Option A: Anthropic API directly
ANTHROPIC_API_KEY=

# Option B: AWS Bedrock (set CLAUDE_CODE_USE_BEDROCK=1 to enable)
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# DEFAULT_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- GitHub ---
# Personal Access Token with repo:read scope on the target organization
GITHUB_PAT=
# Default GitHub organization (used if not specified in request)
GITHUB_ORG=

# --- Supabase / Guardiao ---
# The Edge Function endpoint that receives audit results
GUARDIAO_CALLBACK_URL=https://YOUR_PROJECT.supabase.co/functions/v1/YOUR_FUNCTION_NAME
# Cron secret matching the value in Supabase Vault (for x-cron-secret header)
GUARDIAO_CRON_SECRET=

# --- Redis ---
# Password for Redis (used by docker-compose --requirepass and by REDIS_URL)
REDIS_PASSWORD=
# Full Redis connection URL (used by api and worker)
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@redis:6379

# --- Limits ---
# Max time (minutes) for each Claude CLI pass
AUDIT_TIMEOUT_MINUTES=25
REVIEW_TIMEOUT_MINUTES=15
# Max cloned repo size before warning (MB)
MAX_REPO_SIZE_MB=500
# Git clone depth
CLONE_DEPTH=1

# --- Paths (Docker defaults, override for local dev) ---
# WORK_DIR=/workdir
# FAILED_SUBMISSIONS_DIR=/data/failed-submissions

# --- Server ---
PORT=3000
