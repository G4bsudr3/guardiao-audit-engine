# =============================================================================
# Guardiao Audit Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Service Auth ---
# Pre-shared API key for authenticating requests to this service.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_SERVICE_API_KEY=

# --- Claude ---
# Anthropic API key for Claude Code CLI
ANTHROPIC_API_KEY=

# --- GitHub ---
# Personal Access Token with repo:read scope on the target organization
GITHUB_PAT=
# Default GitHub organization (used if not specified in request)
GITHUB_ORG=

# --- Supabase / Guardiao ---
# The Edge Function endpoint that receives audit results
GUARDIAO_CALLBACK_URL=https://YOUR_PROJECT.supabase.co/functions/v1/ingest-audit-results
# Cron secret matching the value in Supabase Vault (for x-cron-secret header)
GUARDIAO_CRON_SECRET=

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Limits ---
# Max time (minutes) for each Claude CLI pass
AUDIT_TIMEOUT_MINUTES=25
REVIEW_TIMEOUT_MINUTES=15
# Max cloned repo size before warning (MB)
MAX_REPO_SIZE_MB=500
# Git clone depth
CLONE_DEPTH=1

# --- Paths (Docker defaults, override for local dev) ---
# WORK_DIR=/workdir
# FAILED_SUBMISSIONS_DIR=/data/failed-submissions

# --- Server ---
PORT=3000
